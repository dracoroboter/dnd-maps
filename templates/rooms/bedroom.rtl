# Camera da letto — metafile grammatica RTL v0.2
#
# Un letto (o due) contro il muro.
# Un forziere opzionale per letto, preferibilmente vicino al letto.
#
# Parser: tech/scripts/rtl-to-json.py
# Specifica: tech/rules/RTL-spec.md

template "bedroom":
    min_size: 3x3

    bed required 1 to 2 fill: against_wall

    chest optional 1 per bed: next_to bed, corner_any, against_wall_any

    constraints: no_overlap
    todo: door_clearance
